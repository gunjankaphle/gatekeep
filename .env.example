# Snowflake Configuration
SNOWFLAKE_ACCOUNT=your-account
SNOWFLAKE_USER=your-user
SNOWFLAKE_PASSWORD=your-password
SNOWFLAKE_DATABASE=your-database
SNOWFLAKE_WAREHOUSE=your-warehouse
SNOWFLAKE_ROLE=ACCOUNTADMIN

# PostgreSQL Configuration (OPTIONAL - for audit logging)
# If not configured, GateKeep will run without audit logging
# POSTGRES_DSN=postgres://user:pass@localhost:5432/gatekeep?sslmode=disable
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=gatekeep
# POSTGRES_PASSWORD=gatekeep
# POSTGRES_DB=gatekeep

# Server Configuration (API Server)
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# API Configuration
GATEKEEP_CONFIG_PATH=configs/example.yaml  # Path to YAML config for API

# Sync Configuration
SYNC_WORKERS=10
SYNC_TIMEOUT=300s
SYNC_MODE=strict  # strict or additive
SYNC_CIRCUIT_BREAKER_THRESHOLD=0.2  # Stop if >20% operations fail

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json  # json or text

# Audit
AUDIT_RETENTION_DAYS=90

# LocalStack Configuration (OPTIONAL - for integration testing)
# Set USE_LOCALSTACK=true to use LocalStack Snowflake emulator instead of real Snowflake
# USE_LOCALSTACK=true
# LOCALSTACK_AUTH_TOKEN=your-localstack-pro-token  # Required for Snowflake emulator
# LOCALSTACK_HOST=localhost
# LOCALSTACK_PORT=4566
# LOCALSTACK_SNOWFLAKE_ACCOUNT=test
# LOCALSTACK_SNOWFLAKE_USER=test
# LOCALSTACK_SNOWFLAKE_PASSWORD=test
# LOCALSTACK_SNOWFLAKE_DATABASE=TEST_DB
# LOCALSTACK_SNOWFLAKE_WAREHOUSE=ANALYTICS_WH
